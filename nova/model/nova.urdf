<?xml version="1.0"?>
<robot name="nova" xmlns="http://www.ros.org">

    <!-- Base Footprint -->
    <link name="base_footprint" />
    
    <!-- Base Body -->
    <!-- Base Body -->
    <link name="bot_body">
        <visual>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/bot_body.stl" scale="0.2 0.2 0.15"/>
            </geometry>
            <material name="blue">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/bot_body.stl" scale="0.2 0.2 0.15"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 -0.5 -1" rpy="0 0 0" />
            <mass value="5.0" />
            <inertia ixx="0.06" ixy="0.0" ixz="0.0" iyy="0.06" iyz="0.0" izz="0.1" />
        </inertial>
    </link>
    <gazebo reference="bot_body">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- Left Wheel -->
    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/wheel.STL" scale="0.8 0.8 0.85"/>
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/wheel.STL" scale="0.8 0.8 0.85"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>
    <gazebo reference="right_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.8</mu1>
        <mu2>0.8</mu2>
    </gazebo>

    <!-- Right Wheel -->
    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 -1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/wheel.STL" scale="0.8 0.8 0.85"/>
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 -1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/wheel.STL" scale="0.8 0.8 0.85"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>
    <gazebo reference="left_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.8</mu1>
        <mu2>0.8</mu2>
    </gazebo>

    <!-- Caster Part -->
    <link name="caster_part">
        <visual>
            <origin xyz ="0 0 0" rpy="1.57079632679 3.14159265359 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/caster_part.STL" scale="0.5 0.5 0.5"/>
            </geometry>
            <material name="green">
                <color rgba="0 1 0 1"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.5" />
            <inertia ixx="0.00135" ixy="0.0" ixz="0.0" iyy="0.00135" iyz="0.0" izz="0.002" />
        </inertial>
    </link>
    <gazebo reference="caster_part">
        <material>Gazebo/Green</material>
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
    </gazebo>

    <!-- Caster Wheel -->
    <link name="caster_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/caster_wheel.STL" scale="0.5 0.5 1.2"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
            <geometry>
                <mesh filename="file:///home/shubh/ros2_ws/src/nova/meshes/caster_wheel.STL" scale="0.5 0.5 0.7"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>
    <gazebo reference="caster_wheel">
        <material>Gazebo/Blue</material>
        <mu1>0.5</mu1>
        <mu2>0.5</mu2>
    </gazebo>
    
    <!-- LIDAR -->
    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.04"/>
            </geometry>
            <material name="yellow">
                <color rgba="1 1 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="15"/>
            <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
        </inertial>
    </link>
    <gazebo reference="lidar_link">
        <material>Gazebo/Yellow</material>
    </gazebo>
    
    <!-- Joints -->
    
    <joint name="base" type="fixed">
        <parent link="base_footprint"/>
        <child link="bot_body"/>
        <origin xyz="0.0 0.0 0.0"/>
        <axis xyz="0 0 0"/>
    </joint>
    
    <joint name="right_wheel_joint" type="continuous">
        <parent link="bot_body"/>
        <child link="right_wheel"/>
        <origin xyz="0.285 -0.244 -0.13"/>
        <axis xyz="-1 0 0"/>
    </joint>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="bot_body"/>
        <child link="left_wheel"/>
        <origin xyz="-0.285 -0.244 -0.13"/>
        <axis xyz="-1 0 0"/>
    </joint>

    <joint name="caster_part_joint" type="continuous">
        <parent link="bot_body"/>
        <child link="caster_part"/>
        <origin xyz="0 0.2 -0.15"/>
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="caster_wheel_joint" type="continuous">
        <parent link="caster_part"/>
        <child link="caster_wheel"/>
        <origin xyz="0 -0.027 -0.072"/>
        <axis xyz="1 0 0"/>
    </joint>
    
    <joint name="lidar_joint" type="fixed">
        <parent link="bot_body"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.165" rpy="0.0 0.0 0.0"/>
    </joint>
    
    <!-- Gazebo LIDAR -->
    <gazebo reference="lidar_link">
        <sensor type="ray" name="lidar_sensor">
            <pose>0 0 0 0 0 0</pose>
            <visualize>false</visualize>
            <update_rate>40</update_rate>
            <ray>
                <scan>
                  <horizontal>
                      <samples>720</samples>
                      <resolution>1</resolution>
                      <min_angle>-3.14159</min_angle>
                      <max_angle>3.14159</max_angle>
                      </horizontal>
                </scan>
                <range>
                  <min>0.1</min>
                  <max>30.0</max>
                  <resolution>0.1</resolution>
                </range>
            </ray>
            <plugin name="gazebo_ros_lidar_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <argument>~/out:=scan</argument>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>lidar_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>
    
    <!-- Gazebo Properties -->
    <gazebo>
        <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
            </ros>
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            
            <wheel_separation>0.86</wheel_separation>
            <wheel_diameter>0.37</wheel_diameter>
            
            <max_wheel_torque>5</max_wheel_torque>
            <max_wheel_accelaration>5</max_wheel_accelaration>
            
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>bot_body</robot_base_frame>
            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
            <cmd_vel_topic>cmd_vel</cmd_vel_topic>
        </plugin>
    </gazebo>
</robot>